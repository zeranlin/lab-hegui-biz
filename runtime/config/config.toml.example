# hegui-agent 独立 Codex 配置模板

model_provider = "qwen-compatible"
model = "qwen3.6"
model_reasoning_effort = "high"

[model_providers.qwen-compatible]
name = "qwen-compatible"
wire_api = "responses"
requires_openai_auth = false
base_url = "https://example.com/v1"
env_key = "QWEN_API_KEY"

[projects."/Users/linzeran/code/2026-zn/compliance-lab/lab-hegui-llm"]
trust_level = "trusted"

[features]
multi_agent = false
